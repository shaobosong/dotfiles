#!/usr/bin/env bash
# =====================================================================
# Set Terminal Title
# =====================================================================

_terminal_title_hook() {
    printf '\033]0;%s\007' \
        "${PWD/#$HOME/\~}"
}

# =====================================================================
# Set History Sync
# =====================================================================

_history_sync_hook() {
    history -a
    # history -n
}

# =====================================================================
# Interactive Ghost Path
# =====================================================================

GHOST_VIRTUAL_PATH="$PWD"

_status_signal_name() {
    local status=$1
    local signal_number
    local signal_name

    if (( status <= 128 )); then
        return 1
    fi

    signal_number=$((status - 128))
    if ! signal_name=$(builtin kill -l "${signal_number}" 2>/dev/null); then
        return 1
    fi

    printf 'SIG%s' "${signal_name}"
}

_update_ps1_hook() {
    local last_status=$?
    local signal_name=""
    local weekday=""
    local moon_phase="🌑"

    # local COLOR_PREFIX="\e[38;5;2m"

    local COLOR_BLACK="\e[1;30m"
    local COLOR_RED="\e[1;31m"
    local COLOR_GREEN="\e[1;32m"
    local COLOR_YELLOW="\e[1;33m"
    local COLOR_BLUE="\e[1;34m"
    local COLOR_MAGENTA="\e[1;35m"
    local COLOR_CYAN="\e[1;36m"
    local COLOR_WHITE="\e[1;37m"
    local COLOR_RESET="\e[0m"

    local COLOR_DIM_BLACK="\e[2;30m"
    local COLOR_DIM_RED="\e[2;31m"
    local COLOR_DIM_GREEN="\e[2;32m"
    local COLOR_DIM_YELLOW="\e[2;33m"
    local COLOR_DIM_BLUE="\e[2;34m"
    local COLOR_DIM_MAGENTA="\e[2;35m"
    local COLOR_DIM_CYAN="\e[2;36m"
    local COLOR_DIM_WHITE="\e[2;37m"

    local COLOR_RESET="\e[0m"

    # local prefix="\u@\h:"
    # local old_0=""
    local real=""
    # local old_1=""
    local ghost=""

    # too funky
    while test ! -d ${GHOST_VIRTUAL_PATH}; do
        GHOST_VIRTUAL_PATH=${GHOST_VIRTUAL_PATH%/*}
    done

    if [[ "${GHOST_VIRTUAL_PATH%/}"/ != "${PWD%/}"/* ]]; then
        GHOST_VIRTUAL_PATH="$PWD"
    fi

    # if [[ -d "$OLDPWD" && "${PWD%/}"/ == "${OLDPWD%/}"/* ]]; then
    #     old_0="${OLDPWD/#$HOME/\~}"
    #     real="${PWD#$OLDPWD}"
    #     ghost="${GHOST_VIRTUAL_PATH#$PWD}"
    # elif [[ -d "$OLDPWD" && "${OLDPWD%/}"/ == "${PWD%/}"/* ]]; then
    #     old_0="${PWD/#$HOME/\~}"
    #     old_1="${OLDPWD#$PWD}"
    #     ghost="${GHOST_VIRTUAL_PATH#$OLDPWD}"
    # else
    #     real="${PWD/#$HOME/\~}"
    # fi

    real="${PWD/#$HOME/\~}"
    ghost="${GHOST_VIRTUAL_PATH#$PWD}"

    PS1="\n"
    # PS1+="${COLOR_PREFIX}${prefix}${COLOR_RESET}"
    if test ${last_status} -eq 0; then
        # [[ -n "$old_0" ]] && \
        #     PS1+="${COLOR_GREEN}${old_0}${COLOR_RESET}"
        [[ -n "$real" ]] && \
            PS1+="${COLOR_GREEN}${real}${COLOR_RESET}"
        # [[ -n "$old_1" ]] && \
        #     PS1+="${COLOR_DIM_GREEN}${old_1}${COLOR_RESET}"
        [[ -n "$ghost" ]] && \
            PS1+="${COLOR_DIM_GREEN}${ghost}${COLOR_RESET}"
    else
        signal_name=$(_status_signal_name "${last_status}") || signal_name=""
        # [[ -n "$old_0" ]] && \
        #     PS1+="${COLOR_RED}${old_0}${COLOR_RESET}"
        [[ -n "$real" ]] && \
            PS1+="${COLOR_YELLOW}${real}${COLOR_RESET}"
        # [[ -n "$old_1" ]] && \
        #     PS1+="${COLOR_DIM_RED}${old_1}${COLOR_RESET}"
        [[ -n "$ghost" ]] && \
            PS1+="${COLOR_DIM_YELLOW}${ghost}${COLOR_RESET}"
        [[ -n "$signal_name" ]] && \
            PS1+=" ${COLOR_RED}${signal_name}${COLOR_RESET}"
        PS1+=" ${COLOR_RED}(${last_status})${COLOR_RESET}"
    fi

    printf -v weekday '%(%u)T' -1
    case "${weekday}" in
        1) moon_phase="🌑" ;;
        2) moon_phase="🌒" ;;
        3) moon_phase="🌓" ;;
        4) moon_phase="🌔" ;;
        5) moon_phase="🌕" ;;
        6) moon_phase="🌝" ;;
        7) moon_phase="🌚" ;;
    esac

    PS1+="\n${moon_phase} "
}

PROMPT_COMMAND+=(_terminal_title_hook)
PROMPT_COMMAND+=(_history_sync_hook)
PROMPT_COMMAND+=(_update_ps1_hook)
